<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record model="ir.module.category" id="module_category_hr_overtime">
            <field name="name">Overtime</field>
            <field name="description">Helps you manage your employee's overtime records.</field>
            <field name="sequence">11</field>
        </record>

        <!-- Rules -->
        <record id="hr_overtime_personal_rule" model="ir.rule">
            <field name="name">Personal Overtime</field>
            <field ref="model_hr_overtime" name="model_id"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_overtime_manager_rule" model="ir.rule">
            <field name="name">Manager Overtime</field>
            <field ref="model_hr_overtime" name="model_id"/>
            <field name="domain_force">['|', ('manager_id.user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        </record>

        <record id="hr_overtime_admin_rule" model="ir.rule">
            <field name="name">All Overtime</field>
            <field ref="model_hr_overtime" name="model_id"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>
    </data>
</odoo>
