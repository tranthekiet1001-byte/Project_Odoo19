<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_hr_overtime_search" model="ir.ui.view">
        <field name="name">hr.overtime.search</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <search string="Search Overtime">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="department_id"/>
                <field name="project_id"/>
                
                <filter string="My Overtimes" name="my_overtimes" domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Manager" name="group_by_manager" context="{'group_by': 'manager_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="group_by_month" context="{'group_by': 'date_start:month'}"/>
                </group>

                <searchpanel>
                    <field name="department_id" icon="fa-users" enable_counters="1"/>
                    <field name="state" icon="fa-tasks" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_hr_overtime_tree" model="ir.ui.view">
        <field name="name">hr.overtime.list</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <list string="Overtime Requests" sample="1" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="name" optional="show"/>
                <field name="employee_id" options="{'no_create_edit': True}"/>
                <field name="department_id" optional="show" options="{'no_create_edit': True}"/>
                <field name="manager_id" optional="hide"/>
                <field name="project_id" optional="show" options="{'no_create_edit': True}"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="total_hours" sum="Total Hours"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_overtime_form" model="ir.ui.view">
        <field name="name">hr.overtime.form</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <form string="Overtime Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="hr.group_hr_user"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-secondary" invisible="state != 'submitted'" groups="hr.group_hr_user"/>
                    <button name="action_draft" string="Set to Draft" type="object" class="btn-secondary" invisible="state not in ('rejected', 'approved')" groups="hr.group_hr_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'" options="{'no_create_edit': True}"/>
                            <field name="department_id" readonly="state != 'draft'" options="{'no_create_edit': True}"/>
                            <field name="manager_id" readonly="1"/>
                            <field name="project_id" readonly="state != 'draft'" options="{'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="date_start" readonly="state != 'draft'"/>
                            <field name="date_end" readonly="state != 'draft'"/>
                            <field name="total_hours"/>
                            <field name="timesheet_id" invisible="not timesheet_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Note/Reason">
                            <field name="note" readonly="state != 'draft'" placeholder="Add reason for overtime..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_overtime" model="ir.actions.act_window">
        <field name="name">Overtime Requests</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_overtime_search"/>
        <field name="context">{'search_default_my_overtimes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Overtime Request
            </p>
            <p>
                Keep track of your extra working hours and get approvals from your manager.
            </p>
        </field>
    </record>
</odoo>
