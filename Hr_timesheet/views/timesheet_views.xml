<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban View -->
    <record id="view_timesheet_entry_kanban" model="ir.ui.view">
        <field name="name">class.timesheet.entry.kanban</field>
        <field name="model">class.timesheet.entry</field>
        <field name="arch" type="xml">
            <kanban default_group_by="class_payroll_status" class="o_kanban_small_column" records_draggable="1">
                <field name="class_name"/>
                <field name="teacher_id"/>
                <field name="duration"/>
                <field name="class_payroll_status"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click #{record.class_payroll_status.raw_value == 'success' ? 'bg-success text-white' : (record.class_payroll_status.raw_value == 'cancelled' ? 'bg-danger text-white' : 'bg-info text-white')}">
                            <div class="o_kanban_record_title">
                                <strong><field name="class_name"/></strong>
                            </div>
                            <div>
                                Teacher: <field name="teacher_id"/>
                            </div>
                            <div>
                                Duration: <field name="duration"/> hours
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_timesheet_entry_list" model="ir.ui.view">
        <field name="name">class.timesheet.entry.list</field>
        <field name="model">class.timesheet.entry</field>
        <field name="arch" type="xml">
            <list string="Timesheet Entries">
                <field name="class_name"/>
                <field name="teacher_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="duration"/>
                <field name="class_payroll_status" widget="badge" 
                       decoration-success="class_payroll_status == 'success'" 
                       decoration-danger="class_payroll_status == 'cancelled'" 
                       decoration-info="class_payroll_status == 'upcoming'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_timesheet_entry_form" model="ir.ui.view">
        <field name="name">class.timesheet.entry.form</field>
        <field name="model">class.timesheet.entry</field>
        <field name="arch" type="xml">
            <form string="Timesheet Entry">
                <header>
                    <field name="class_payroll_status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="class_name" placeholder="Class Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="duration"/>
                        </group>
                        <group>
                            <field name="start_time"/>
                            <field name="end_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_timesheet_entry_search" model="ir.ui.view">
        <field name="name">class.timesheet.entry.search</field>
        <field name="model">class.timesheet.entry</field>
        <field name="arch" type="xml">
            <search string="Search Timesheet Entries">
                <field name="class_name"/>
                <field name="teacher_id"/>
                <filter string="Successfully Taught" name="success" domain="[('class_payroll_status', '=', 'success')]"/>
                <filter string="Upcoming" name="upcoming" domain="[('class_payroll_status', '=', 'upcoming')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('class_payroll_status', '=', 'cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Teacher" name="group_teacher" context="{'group_by': 'teacher_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'class_payroll_status'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
