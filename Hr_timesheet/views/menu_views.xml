<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->
    <record id="action_timesheet_entry" model="ir.actions.act_window">
        <field name="name">Teacher Timesheets</field>
        <field name="res_model">class.timesheet.entry</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new teacher timesheet entry!
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_teacher_timesheet_root" name="Teacher Timesheet" sequence="10"/>
    
    <menuitem id="menu_teacher_timesheet_entry" name="Timesheets" parent="menu_teacher_timesheet_root" action="action_timesheet_entry" sequence="10"/>

</odoo>
