<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_work_planned_list" model="ir.ui.view">
        <field name="name">hr.work.planned.list</field>
        <field name="model">hr.work.planned</field>
        <field name="arch" type="xml">
            <list string="Work Planned Schedules">
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="planned_hours" widget="float_time"/>
                <field name="status" widget="badge"/>
                <field name="department_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_work_planned_kanban" model="ir.ui.view">
        <field name="name">hr.work.planned.kanban</field>
        <field name="model">hr.work.planned</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="employee_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_content">
                                <div>
                                    <strong>
                                        <field name="employee_id"/>
                                    </strong>
                                </div>
                                <div>
                                    <i class="fa fa-calendar"/>
                                    <field name="date_start"/>
                                    -
                                    <field name="date_end"/>
                                </div>
                                <div>
                                    <field name="status" widget="badge"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_work_planned_form" model="ir.ui.view">
        <field name="name">hr.work.planned.form</field>
        <field name="model">hr.work.planned</field>
        <field name="arch" type="xml">
            <form string="Work Planned Schedule">
                <header>
                    <button string="Approve"
                            name="action_approve"
                            type="object"
                            class="btn btn-primary"
                            invisible="status != 'draft'"/>

                    <button string="Reject"
                            name="action_reject"
                            type="object"
                            class="btn btn-danger"
                            invisible="status != 'draft'"/>

                    <button string="Reset to Draft"
                            name="action_reset_to_draft"
                            type="object"
                            class="btn btn-secondary"
                            invisible="status not in ('approved', 'rejected')"/>

                    <field name="status" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                        </group>

                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="planned_hours" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <field name="description"
                               placeholder="Add notes about this planned shift..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_work_planned" model="ir.actions.act_window">
        <field name="name">Work Planned</field>
        <field name="res_model">hr.work.planned</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No work planned schedules found. Create one!
            </p>
            <p>
                Use this view to manage and track approved work schedules for employees.
                Only approved shifts will be recognized in attendance tracking.
            </p>
        </field>
    </record>

    <!-- MENU ITEM -->
    <menuitem id="menu_hr_work_planned"
              name="Work Planned"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_work_planned"
              sequence="30"/>

</odoo>