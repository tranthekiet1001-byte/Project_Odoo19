<odoo>
    <record id="view_remote_work_request_search" model="ir.ui.view">
        <field name="name">a.remote.work.request.search</field>
        <field name="model">a.remote.work.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Request Name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <filter string="Date Range" name="date_range" date="start_date"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected" domain="[('state', '=', 'rejected')]"/>
            </search>
        </field>
    </record>

    <record id="view_remote_work_request_kanban" model="ir.ui.view">
        <field name="name">a.remote.work.request.kanban</field>
        <field name="model">a.remote.work.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_grouped o_remote_work_request_kanban">
                <field name="state"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record">
                            <div class="o_kanban_record_top">
                                <field name="name"/>
                            </div>
                            <div class="o_kanban_content">
                                <strong>Employee:</strong> <field name="employee_id"/>
                            </div>
                            <div class="o_kanban_content">
                                <strong>Start:</strong> <field name="start_date"/> <strong>End:</strong> <field name="end_date"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_remote_work_request_form" model="ir.ui.view">
        <field name="name">a.remote.work.request.form</field>
        <field name="model">a.remote.work.request</field>
        <field name="arch" type="xml">
            <form string="Remote Work Request" class="o_remote_work_request_form">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn btn-primary o_remote_work_request_header_button" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn btn-success o_remote_work_request_header_button" invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn btn-danger o_remote_work_request_header_button" invisible="state != 'submitted'"/>
                    <button string="Save" special="save" class="btn btn-secondary o_remote_work_request_header_button"/>
                    <button string="Discard" special="cancel" class="btn btn-default o_discard_button o_remote_work_request_header_button"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <group class="o_remote_work_request_section">
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="manager_id"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="company_id"/>
                            <field name="work_type"/>
                        </group>
                    </group>
                    <group class="o_remote_work_request_section">
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group class="o_remote_work_request_section">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_remote_work_request_tree" model="ir.ui.view">
        <field name="name">a.remote.work.request.tree</field>
        <field name="model">a.remote.work.request</field>
        <field name="arch" type="xml">
            <list string="Remote Work Requests">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="department_id"/>
                <field name="state"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>
</odoo>
