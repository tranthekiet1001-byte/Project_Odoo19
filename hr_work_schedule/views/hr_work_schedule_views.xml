<odoo>
    <record id="view_hr_work_schedule_search" model="ir.ui.view">
        <field name="name">hr.work.schedule.search</field>
        <field name="model">hr.work.schedule</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm công ca">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                
                <filter string="Giáo viên của tôi" name="my_schedule" domain="[('employee_id.user_id', '=', uid)]"/>
                
                <separator/>
                
                <filter string="Đã duyệt (Approved)" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Chờ duyệt (Submitted)" name="submitted" domain="[('state', '=', 'submitted')]"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter string="Giáo viên" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Công ty/Chi nhánh" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Tháng bắt đầu" name="group_date" context="{'group_by': 'start_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_hr_work_schedule_kanban" model="ir.ui.view">
        <field name="name">hr.work.schedule.kanban</field>
        <field name="model">hr.work.schedule</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong><br/>
                            <span><field name="employee_id"/></span><br/>
                            <span><field name="start_date"/> - <field name="end_date"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_hr_work_schedule_form" model="ir.ui.view">
        <field name="name">hr.work.schedule.form</field>
        <field name="model">hr.work.schedule</field>
        <field name="arch" type="xml">
            <form string="Work Schedule">
                <header>
                    <button string="Approve" type="object" name="action_approve" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button string="Reject" type="object" name="action_reject" invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_work_schedule" model="ir.actions.act_window">
        <field name="name">Work Schedules</field>
        <field name="res_model">hr.work.schedule</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_hr_work_schedule_search"/>
    </record>
    
    <menuitem id="menu_hr_work_schedule_root" name="Work Schedules" parent="hr_attendance.menu_hr_attendance_root" sequence="10"/>
    <menuitem id="menu_hr_work_schedule" name="Work Schedule" parent="menu_hr_work_schedule_root" action="action_hr_work_schedule"/>
</odoo>