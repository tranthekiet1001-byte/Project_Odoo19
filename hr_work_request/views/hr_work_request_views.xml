<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====================================================================
         FORM VIEW — Odoo 18 compatible, wide-screen layout
    ===================================================================== -->
    <record id="hr_work_request_view_form" model="ir.ui.view">
        <field name="name">hr.work.request.form</field>
        <field name="model">hr.work.request</field>
        <field name="arch" type="xml">
            <form string="Đơn làm việc Online / Công tác">

                <header>
                    <button name="action_confirm"
                            string="Gửi duyệt"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_validate"
                            string="Phê duyệt"
                            type="object"
                            class="oe_highlight"
                            groups="hr_attendance.group_hr_attendance_manager"
                            invisible="state != 'confirm'"/>
                    <button name="action_refuse"
                            string="Từ chối"
                            type="object"
                            groups="hr_attendance.group_hr_attendance_manager"
                            invisible="state not in ('confirm', 'validate')"/>
                    <button name="action_reset_draft"
                            string="Đặt lại Nháp"
                            type="object"
                            invisible="state not in ('confirm', 'refuse')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirm,validate"/>
                </header>

                <sheet>

                    <!-- Mã đơn -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Banner từ chối — dùng field trực tiếp, không lồng trong span -->
                    <field name="refuse_reason"
                           invisible="state != 'refuse'"
                           readonly="1"
                           widget="text"
                           class="alert alert-danger"/>

                    <!-- ===========================================================
                         NHÓM 1: Thông tin nhân viên + Loại đơn & thời gian
                         (2 cột trên màn hình rộng)
                    =========================================================== -->
                    <group>
                        <group string="Thông tin nhân viên" col="2">
                            <field name="employee_id"
                                   readonly="state != 'draft'"
                                   required="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                            <field name="company_id" readonly="1"
                                   groups="base.group_multi_company"/>
                        </group>

                        <group string="Loại đơn &amp; Thời gian" col="2">
                            <field name="request_type"
                                   widget="radio"
                                   readonly="state != 'draft'"
                                   required="1"/>
                            <field name="date_from"
                                   readonly="state != 'draft'"
                                   required="1"/>
                            <field name="date_to"
                                   readonly="state != 'draft'"
                                   required="1"/>
                            <field name="number_of_days" readonly="1"/>
                        </group>
                    </group>

                    <!-- ===========================================================
                         NHÓM 2: Nội dung đơn (full width)
                    =========================================================== -->
                    <group string="Nội dung &amp; Lý do">
                        <field name="reason"
                               readonly="state != 'draft'"
                               required="1"
                               placeholder="Nêu rõ lý do và mục đích..."
                               nolabel="1"
                               colspan="2"/>
                        <field name="task_description"
                               readonly="state != 'draft'"
                               placeholder="Mô tả các công việc sẽ thực hiện..."
                               nolabel="1"
                               colspan="2"/>
                    </group>

                    <!-- ===========================================================
                         NHÓM 3A: Thông tin WFH (chỉ hiện khi online)
                    =========================================================== -->
                    <group string="Thông tin làm việc Online"
                           invisible="request_type != 'online'">
                        <field name="work_location"
                               readonly="state != 'draft'"
                               placeholder="Nhà riêng, quán cafe, coworking space..."/>
                    </group>

                    <!-- ===========================================================
                         NHÓM 3B: Thông tin công tác (chỉ hiện khi business_trip)
                    =========================================================== -->
                    <group string="Thông tin Công tác"
                           invisible="request_type != 'business_trip'">
                        <group>
                            <field name="destination"
                                   readonly="state != 'draft'"
                                   required="request_type == 'business_trip'"
                                   placeholder="Thành phố / địa điểm công tác"/>
                            <field name="transport_mode"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="estimated_cost"
                                   readonly="state != 'draft'"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- ===========================================================
                         NHÓM 4: Kết quả duyệt (chỉ hiện sau khi gửi)
                    =========================================================== -->
                    <group string="Kết quả phê duyệt"
                           invisible="state == 'draft'">
                        <group>
                            <field name="validated_by" readonly="1"/>
                            <field name="validation_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="refuse_reason" readonly="1"
                                   invisible="state != 'refuse'"/>
                        </group>
                    </group>

                </sheet>

                <!-- CHATTER — file đính kèm dùng paperclip trong chatter -->
                <chatter/>

            </form>
        </field>
    </record>


    <!-- ====================================================================
         LIST VIEW
    ===================================================================== -->
    <record id="hr_work_request_view_list" model="ir.ui.view">
        <field name="name">hr.work.request.list</field>
        <field name="model">hr.work.request</field>
        <field name="arch" type="xml">
            <list string="Đơn làm việc"
                  decoration-info="state == 'confirm'"
                  decoration-success="state == 'validate'"
                  decoration-danger="state == 'refuse'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="request_type" widget="badge"
                       decoration-info="request_type == 'online'"
                       decoration-warning="request_type == 'business_trip'"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="number_of_days" string="Số ngày"/>
                <field name="reason" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'confirm'"
                       decoration-success="state == 'validate'"
                       decoration-danger="state == 'refuse'"/>
                <button name="action_confirm" type="object"
                        icon="fa-paper-plane" title="Gửi duyệt"
                        invisible="state != 'draft'"/>
                <button name="action_validate" type="object"
                        icon="fa-check" title="Phê duyệt"
                        groups="hr_attendance.group_hr_attendance_manager"
                        invisible="state != 'confirm'"/>
            </list>
        </field>
    </record>


    <!-- ====================================================================
         SEARCH VIEW
    ===================================================================== -->
    <record id="hr_work_request_view_search" model="ir.ui.view">
        <field name="name">hr.work.request.search</field>
        <field name="model">hr.work.request</field>
        <field name="arch" type="xml">
            <search string="Tìm đơn làm việc">
                <field name="name" string="Mã đơn"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="reason"/>
                <!-- Filter: Nhân viên xem đơn của chính mình -->
                <filter string="Đơn của tôi" name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <!-- Filter: Manager xem đơn cần mình duyệt -->
                <filter string="Cần tôi duyệt" name="need_my_approval"
                        domain="[('manager_id.user_id', '=', uid), ('state', '=', 'confirm')]"/>
                <filter string="Làm việc Online" name="filter_online"
                        domain="[('request_type', '=', 'online')]"/>
                <filter string="Công tác" name="filter_business_trip"
                        domain="[('request_type', '=', 'business_trip')]"/>
                <separator/>
                <filter string="Nháp"       name="draft"    domain="[('state','=','draft')]"/>
                <filter string="Chờ duyệt"  name="confirm"  domain="[('state','=','confirm')]"/>
                <filter string="Đã duyệt"   name="validate" domain="[('state','=','validate')]"/>
                <filter string="Từ chối"    name="refuse"   domain="[('state','=','refuse')]"/>
                <filter string="Tất cả"     name="all"      domain="[]"/>
                <separator/>
                <filter string="Tháng này" name="this_month"
                        domain="[('date_from','&gt;=',(context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên"  name="group_employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Phòng ban"  name="group_dept"     context="{'group_by':'department_id'}"/>
                    <filter string="Loại đơn"   name="group_type"     context="{'group_by':'request_type'}"/>
                    <filter string="Trạng thái" name="group_state"    context="{'group_by':'state'}"/>
                    <filter string="Tháng"      name="group_month"    context="{'group_by':'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>


    <!-- ====================================================================
         ACTION WINDOW
    ===================================================================== -->
    <record id="hr_work_request_action" model="ir.actions.act_window">
        <field name="name">Đơn làm việc Online / Công tác</field>
        <field name="res_model">hr.work.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_work_request_view_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có đơn nào!</p>
            <p>Tạo đơn <b>Làm việc Online (WFH)</b> hoặc <b>Công tác</b> để gửi quản lý phê duyệt.</p>
        </field>
    </record>

    <record id="hr_work_request_action_manager" model="ir.actions.act_window">
        <field name="name">Duyệt đơn làm việc</field>
        <field name="res_model">hr.work.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_work_request_view_search"/>
        <field name="context">{'search_default_confirm': 1}</field>
    </record>


    <!-- ====================================================================
         WIZARD FORM — Từ chối đơn
    ===================================================================== -->
    <record id="hr_work_request_refuse_wizard_form" model="ir.ui.view">
        <field name="name">hr.work.request.refuse.wizard.form</field>
        <field name="model">hr.work.request.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối đơn">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="refuse_reason"
                           placeholder="Nhập lý do từ chối (bắt buộc)..."
                           required="1"/>
                </group>
                <footer>
                    <button name="action_refuse_confirm"
                            string="Xác nhận từ chối"
                            type="object"
                            class="btn-danger"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
